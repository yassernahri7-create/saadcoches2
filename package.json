{
  "name": "nourcoches",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:website": "node website-server.cjs",
    "dev:admin": "node admin-server.cjs",
    "dev:all": "concurrently \"npm run dev\" \"node website-server.cjs\" \"node admin-server.cjs\"",
    "build": "tsc -b && vite build",
    "start": "node website-server.cjs",
    "start:website": "node website-server.cjs",
    "start:admin": "node admin-server.cjs",
    "check": "node --check website-server.cjs && node --check admin-server.cjs && node --check backend/site-store.cjs && node --check backend/server-common.cjs",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "dayjs": "^1.11.19",
    "express": "^5.2.1",
    "framer-motion": "^12.34.3",
    "libphonenumber-js": "^1.12.37",
    "lucide-react": "^0.575.0",
    "multer": "^2.0.2",
    "playwright": "^1.58.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  }
}
